{
  "name": "parchmark-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:tokens && vue-tsc --noEmit -p tsconfig.json && vite build",
    "build:tokens": "node src/design-system/tokens/build.mjs",
    "lint": "vue-tsc --noEmit -p tsconfig.json && prettier --check \"src/**/*.{ts,vue}\" \"src/design-system/base.css\" \"*.{html,json,ts}\"",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"src/design-system/base.css\" \"*.{html,json,ts}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "style-dictionary": "^5.4.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
