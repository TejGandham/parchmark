{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keel.framework/schemas/routing.schema.json",
  "title": "KEEL handoff routing",
  "description": "Orchestrator-owned pipeline state. Mutable through scripts/keel-routing.py only. Validated after every write.",
  "type": "object",
  "required": ["schema_version", "work_item", "status", "pipeline", "branch", "review_panel"],
  "additionalProperties": false,
  "allOf": [
    {
      "comment": "Conditional requirements by pipeline. Bootstrap has no resolver step (no source_hash) but names a bootstrap_agent; non-bootstrap requires source_hash (so safe-merge can detect source changes) and the routing block (pre-check output). This is the fix for re-analysis findings C1 (bootstrap_agent read-but-not-in-schema) + C2 (source_hash optional → silent every-run wipe).",
      "if":   { "properties": { "pipeline": { "const": "bootstrap" } } },
      "then": { "required": ["bootstrap_agent"] },
      "else": { "required": ["source_hash", "routing"] }
    }
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 5 },
    "work_item": {
      "type": "object",
      "required": ["id", "slug"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "pattern": "^WI[0-9]{2,}$" },
        "slug":  { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "status":   { "enum": ["IN-PROGRESS", "BLOCKED"] },
    "pipeline": { "enum": ["bootstrap", "backend", "frontend", "cross-cutting", "karta"] },
    "binder_ref":  { "type": ["string", "null"] },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parent_branch": { "type": ["string", "null"] },
        "parent_sha":    { "type": ["string", "null"] }
      }
    },
    "review_panel": { "enum": ["personas", "roundtable", "none"] },
    "source_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Mirror of resolved-work-item.json:.source_hash at last init time. Read by `keel-routing.py init` to decide safe-merge vs invalidate-derived-state. Written by init only; never updated except via init. REQUIRED for non-bootstrap pipelines (see the allOf conditional below) so that omission is a loud validation failure rather than a silent every-run derived-state wipe."
    },
    "bootstrap_agent": {
      "enum": ["scaffolder", "config-writer"],
      "description": "The bootstrap agent named in the backlog Agent: field. REQUIRED for pipeline=bootstrap (see allOf conditional); read by validate-handoff.py's stage-aware expected-file-set to know which bootstrap agent file to expect. Absent for non-bootstrap pipelines."
    },
    "precheck_escalation_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "pretriage": {
      "type": "object",
      "required": ["recommended_model", "score", "reason"],
      "additionalProperties": false,
      "properties": {
        "recommended_model": { "enum": ["sonnet", "opus"] },
        "score":             { "type": "integer", "minimum": 0, "maximum": 9 },
        "reason":            { "type": "string" }
      }
    },
    "routing": {
      "type": "object",
      "required": ["intent", "complexity", "designer_needed", "researcher_needed", "safety_auditor_needed", "arch_advisor_needed", "implementer_needed"],
      "additionalProperties": false,
      "properties": {
        "intent":                { "enum": ["refactoring", "build", "mid-sized", "architecture", "research"] },
        "complexity":            { "enum": ["trivial", "standard", "complex", "architecture-tier"] },
        "designer_needed":       { "type": "boolean" },
        "researcher_needed":     { "type": "boolean" },
        "safety_auditor_needed": { "type": "boolean" },
        "arch_advisor_needed":   { "type": "boolean" },
        "implementer_needed":    { "type": "boolean" }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "comment": "Each gate's verdict is constrained to its agent's canonical verdict set (the file-body **Verdict:** word the orchestrator mirrors via set-gate) plus null (unset). A typo verdict halts the next keel-routing.py write loudly rather than landing silently. Non-gate review touchpoints use $defs/review_touchpoint (APPROVED/CONCERNS) — distinct vocabularies, do not unify.",
      "properties": {
        "spec_review": {
          "type": "object",
          "required": ["attempt"],
          "additionalProperties": false,
          "properties": {
            "verdict": { "enum": ["CONFORMANT", "DEVIATION", null] },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        },
        "safety": {
          "type": "object",
          "required": ["attempt"],
          "additionalProperties": false,
          "properties": {
            "verdict": { "enum": ["PASS", "VIOLATION", null] },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        },
        "code_review": {
          "type": "object",
          "required": ["attempt"],
          "additionalProperties": false,
          "properties": {
            "verdict": { "enum": ["APPROVED", "CONCERNS", null] },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        },
        "arch_verify": {
          "type": "object",
          "required": ["attempt"],
          "additionalProperties": false,
          "properties": {
            "verdict": { "enum": ["SOUND", "UNSOUND", null] },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        },
        "conformance": {
          "type": "object",
          "required": ["attempt"],
          "additionalProperties": false,
          "comment": "Karta lean lane structural conformance gate (karta-spec-reviewer). DEVIATION loops to implementer; SPEC-SUSPECT halts for human adjudication; only CONFORMANT lands.",
          "properties": {
            "verdict": { "enum": ["CONFORMANT", "DEVIATION", "SPEC-SUSPECT", null] },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "arch_retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spec_review_attempt": { "type": "integer", "minimum": 0 },
        "safety_attempt":      { "type": "integer", "minimum": 0 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "precheck": { "$ref": "#/$defs/review_touchpoint" },
        "design":   { "$ref": "#/$defs/review_touchpoint" },
        "landing":  { "$ref": "#/$defs/review_touchpoint" }
      }
    },
    "review_retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code_review_attempt": { "type": "integer", "minimum": 0 },
        "spec_review_attempt": { "type": "integer", "minimum": 0 },
        "safety_attempt":      { "type": "integer", "minimum": 0 }
      }
    },
    "doc_garden": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict":     { "enum": ["CLEAN", "DRIFT_FOUND", null] },
        "drift_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "review_touchpoint": {
      "type": "object",
      "required": ["attempt"],
      "additionalProperties": false,
      "properties": {
        "verdict": { "enum": ["APPROVED", "CONCERNS", null] },
        "attempt": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
