    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.keel/hooks/keel-timing-hook.py\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "async": true,
