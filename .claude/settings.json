    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "filepath=\"$CLAUDE_FILE_PATH\"; [ -z \"$filepath\" ] && exit 0; case \"$filepath\" in *.py) cd \"$CLAUDE_PROJECT_DIR/backend\" && uv run ruff format \"$filepath\" 2>/dev/null && uv run ruff check --fix \"$filepath\" 2>/dev/null ;; *.ts|*.tsx) cd \"$CLAUDE_PROJECT_DIR/ui\" && npx prettier --write \"$filepath\" 2>/dev/null ;; esac; exit 0",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "filepath=\"$CLAUDE_FILE_PATH\"; [ -z \"$filepath\" ] && exit 0; case \"$filepath\" in */markdown.ts|*/markdown.py) echo '\u26a0\ufe0f  Markdown util changed \u2014 run /parchmark-markdown-sync to verify frontend/backend parity' ;; esac; exit 0",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.keel/hooks/keel-doc-gate.py\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.keel/hooks/keel-timing-hook.py\"",
            "type": "command"
